# =========================
# Intercity Bus Booking AI ENV Example
# =========================

# Web
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql
NEXT_PUBLIC_GRAPHQL_WS_URL=ws://localhost:4000/graphql

# GraphQL Gateway
GRAPHQL_GATEWAY_PORT=4000
WEB_ORIGIN=http://localhost:3000

# Service Ports
TRIP_SERVICE_PORT=50051
SEAT_INVENTORY_SERVICE_PORT=50052
BOOKING_SERVICE_PORT=50053
PAYMENT_SERVICE_PORT=5010
ANALYTICS_SERVICE_PORT=50056
MCP_SERVER_PORT=4010
BOOKING_GRPC_TARGET=localhost:50053
SEAT_INVENTORY_GRPC_URL=localhost:50052

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bus_booking
POSTGRES_USER=bus_app
POSTGRES_PASSWORD=change_me_local_only
DATABASE_URL=postgresql://bus_app:change_me_local_only@localhost:5432/bus_booking

# Redis
REDIS_URL=redis://localhost:6379
SEAT_HOLD_TTL_SECONDS=300

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_SEARCH_EVENTS=search-events
KAFKA_TOPIC_BOOKING_EVENTS=booking-events
KAFKA_TOPIC_PAYMENT_EVENTS=payment-events
KAFKA_TOPIC_CHECKIN_EVENTS=checkin-events

# AI
AI_PROVIDER=openai
OPENAI_API_KEY=replace_with_local_key_only

# Simulated Email
EMAIL_MODE=log
EMAIL_FROM=demo-bus@example.com

# Auth
JWT_SECRET=change_me_local_only
