    {
      "name": "6. Public Query - Seat Map",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"SeatMap returns seat data array or service errors\", function () {",
              "    var jsonData = pm.response.json();",
              "    if (jsonData.errors) {",
              "        pm.expect(jsonData.errors).to.be.an('array');",
              "    } else {",
              "        pm.expect(jsonData.data.seatMap).to.be.an('array');",
              "    }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "query SeatMap($tripId: ID!) {\n  seatMap(tripId: $tripId) {\n    id\n    label\n    status\n  }\n}",
            "variables": "{\n  \"tripId\": \"trip-demo-001\"\n}"
          }
        },
        "url": {
          "raw": "{{baseUrl}}",
          "host": [
            "{{baseUrl}}"
          ]
