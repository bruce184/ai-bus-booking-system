    {
      "name": "3. Admin Dashboard - Authorized (Admin)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Build a dynamic 30-day date window so this test never expires.",
              "var to = new Date();",
              "var from = new Date();",
              "from.setDate(from.getDate() - 30);",
              "function fmt(d) {",
              "    return d.toISOString().split('T')[0];",
              "}",
              "pm.environment.set(\"dashboardFrom\", fmt(from));",
              "pm.environment.set(\"dashboardTo\", fmt(to));"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Revenue summary returned successfully\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.errors).to.be.undefined;",
              "    pm.expect(jsonData.data.adminAnalyticsDashboard.revenueSummary.totalRevenue).to.be.a('number');",
              "    pm.expect(jsonData.data.adminAnalyticsDashboard.dailyRevenue).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "query AdminDashboard($input: AdminRevenueSummaryInput!) {\n  adminAnalyticsDashboard(input: $input) {\n    revenueSummary {\n      from\n      to\n      totalRevenue\n      paidBookings\n      ticketsSold\n      successfulBookingRate\n    }\n    dailyRevenue {\n      date\n      revenue\n      paidBookings\n      ticketsSold\n    }\n  }\n}",
            "variables": "{\n  \"input\": {\n    \"from\": \"{{dashboardFrom}}\",\n    \"to\": \"{{dashboardTo}}\"\n  }\n}"
          }
        },
        "url": {
          "raw": "{{baseUrl}}",
          "host": [
            "{{baseUrl}}"
          ]
        }
      }
    },
